{
  // Simulated project package manifest.
  // The workspace looks like a real Next.js application, while the
  // Claude plugin lives separately in .claude/plugins/vision-plugin.

  "name": "example-project",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "next lint",
    "test": "vitest run",
    "review:plugin": "claude --plugin-dir ./.claude/plugins/vision-plugin"
  },
  "dependencies": {
    "next": "15.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "1.51.0",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
