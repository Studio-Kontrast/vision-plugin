{
  // Project-scoped Claude settings for the simulated workspace.
  //
  // The plugin is checked into .claude/plugins/vision-plugin during
  // development so the team can inspect exactly what Claude sees.
  // In a real repo you might install the same plugin from a marketplace
  // and keep only the project-specific rules here.

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_PLUGINS": "1"
  },

  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status)",
      "Bash(npm run lint)",
      "Bash(npm test)"
    ]
  },

  // Local development command:
  //   claude --plugin-dir ./.claude/plugins/vision-plugin
  //
  // The checked-in plugin folder keeps the installation layout visible
  // for design, review, and documentation work.

  "statusLine": {
    "type": "command",
    "command": "git branch --show-current"
  }
}
