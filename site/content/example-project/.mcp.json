{
  // Project-scope MCP config for the consuming workspace.
  // The plugin can recommend external context sources, but MCP servers
  // are configured from the project root so each repository keeps
  // control over its own tokens and integrations.

  "mcpServers": {
    "zeplin": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-zeplin"],
      "env": {
        "ZEPLIN_TOKEN": "${env:ZEPLIN_TOKEN}"
      }
    }

    // Add Notion later if PRDs live outside the repo:
    // "notion": {
    //   "command": "npx",
    //   "args": ["-y", "@anthropic/mcp-notion"],
    //   "env": {
    //     "NOTION_TOKEN": "${env:NOTION_TOKEN}"
    //   }
    // }
  }
}
