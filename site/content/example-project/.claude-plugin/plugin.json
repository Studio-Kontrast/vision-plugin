{
  // .claude-plugin/plugin.json
  //
  // The plugin manifest defines identity, versioning, and discovery
  // metadata. This is the only file that lives inside .claude-plugin/.
  // Skills, agents, hooks, and scripts stay at the plugin root.

  "name": "vision-plugin",
  "description": "Claude Code plugin for review pipelines and architecture patterns used on Studio Kontrast product projects.",
  "version": "0.1.0",

  "author": {
    "name": "Studio Kontrast",
    "url": "https://github.com/studio-kontrast"
  },

  "repository": "https://github.com/studio-kontrast/vision-plugin",
  "license": "UNLICENSED",
  "keywords": [
    "nextjs",
    "pim",
    "dam",
    "erp",
    "e-commerce",
    "review-pipeline"
  ]

  // Claude discovers components automatically:
  //   agents/  -> custom reviewers and helpers
  //   skills/  -> domain knowledge packs
  //   hooks/   -> hook config
  //   .mcp.json -> project-scoped MCP servers
  //
  // Skill names become namespaced slash commands:
  //   /vision-plugin:frontend-patterns
  //   /vision-plugin:git-workflow
}
